# Commission Tracker Environment Configuration Template
# Copy this file to .env and configure for your environment

# Development Strategy
# Safe default: local Supabase via Docker
VITE_USE_LOCAL=true
VITE_ALLOW_REMOTE_SUPABASE_DEV=false

# API Configuration
VITE_API_URL=http://localhost:3001

# Local Supabase configuration (used when VITE_USE_LOCAL=true)
# These defaults match `supabase start` unless you customize the local stack.
VITE_LOCAL_SUPABASE_URL=http://127.0.0.1:54321
VITE_LOCAL_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Remote Supabase configuration (used only when VITE_USE_LOCAL=false)
# Keep remote dev opt-in disabled unless you intentionally want a cloud project.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-remote-anon-key

# User Configuration (optional)
USER_ID=nick
USER_EMAIL=nick@nickneessen.com

# Admin Configuration
# The email address of the admin user who can approve/deny user signups
# This user will be auto-approved and marked as admin on signup
VITE_ADMIN_EMAIL=nick@nickneessen.com

# Local PostgreSQL Database (used by scripts/server.js when running locally)
DB_HOST=localhost
DB_PORT=54322
DB_NAME=postgres
DB_USER=postgres
DB_PASS=postgres

# Local direct DB URL for migrations/scripts
LOCAL_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
LOCAL_SUPABASE_ADMIN_DATABASE_URL=postgresql://supabase_admin:postgres@127.0.0.1:54322/postgres

# Remote DB URL only when you intentionally target a cloud database
DATABASE_URL=
REMOTE_DATABASE_URL=
LOCAL_BOOTSTRAP_SUPER_ADMIN_EMAIL=nickneessen@thestandardhq.com
LOCAL_BOOTSTRAP_SUPER_ADMIN_PASSWORD=LocalSuperAdmin2026!Reset1
LOCAL_BOOTSTRAP_ACTIVE_AGENT_EMAIL=local.agent@thestandardhq.test
LOCAL_BOOTSTRAP_ACTIVE_AGENT_PASSWORD=LocalUser2026!Reset1
LOCAL_BOOTSTRAP_TRAINER_EMAIL=local.trainer@thestandardhq.test
LOCAL_BOOTSTRAP_TRAINER_PASSWORD=LocalUser2026!Reset1
LOCAL_BOOTSTRAP_CONTRACTING_MANAGER_EMAIL=local.contracting@thestandardhq.test
LOCAL_BOOTSTRAP_CONTRACTING_MANAGER_PASSWORD=LocalUser2026!Reset1

# Gmail OAuth Configuration (for email integration)
# Create credentials at: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_GOOGLE_REDIRECT_URI=https://your-project.supabase.co/functions/v1/oauth-callback

# Supabase Infrastructure Monitoring
# Service role key for metrics endpoint access
# Find at: Supabase Dashboard > Project Settings > API Keys > service_role (secret)
SUPABASE_METRICS_PASSWORD=sb_secret_your_key_here

# Development
NODE_ENV=development
