/coverage

# production
/build

# misc
.DS_Store
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Backup / temp env files (created by migration tooling, scripts, editors).
# Must be excluded so credentials never accidentally land in git history.
.env.backup
.env.backup*
.env.bak
.env.bak*
.env.tmp*
.env.swap*
.env.*.backup

npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript
*.tsbuildinfo

# Sensitive documents
public/*.pdf
*.pdf:Zone.Identifier

# Auto-generated continuation prompts
plans/continuation-prompts/

# PreCompact hook logs
.claude/hooks/pre-compact.log
build.log
dev.log
.vercel
.env*.local

