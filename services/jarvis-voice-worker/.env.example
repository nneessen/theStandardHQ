# jarvis-voice-worker env — copy to .env.local for dev; set as Fly secrets for prod.
# (Values for the LIVEKIT_* / DEEPGRAM keys are already in the repo root .env.local.)

# LiveKit Cloud — the worker connects OUT to this and is auto-dispatched into rooms.
LIVEKIT_URL=wss://<your-project>.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Speech-to-text (streaming, keyword-boosted).
DEEPGRAM_API_KEY=

# Text-to-speech.
ELEVENLABS_API_KEY=

# The Claude brain. The worker calls assistant-orchestrator with the END USER's JWT
# (received over the data channel) — these are only the URL + the gateway apikey.
SUPABASE_URL=https://pcyaqwodnyrpkaiojnpz.supabase.co
SUPABASE_ANON_KEY=
