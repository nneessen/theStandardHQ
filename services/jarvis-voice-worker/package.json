{
  "name": "jarvis-voice-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "LiveKit Agents worker for Jarvis realtime voice — Deepgram STT + ElevenLabs TTS + Silero turn-detection, bridged to the Claude assistant-orchestrator (M1 of the voice rebuild).",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "node --import tsx --env-file=.env.local ./src/agent.ts dev",
    "start": "node ./dist/agent.js start"
  },
  "dependencies": {
    "@livekit/agents": "^1.4.5",
    "@livekit/agents-plugin-deepgram": "^1.4.5",
    "@livekit/agents-plugin-elevenlabs": "^1.4.5",
    "@livekit/agents-plugin-silero": "^1.4.5",
    "@livekit/noise-cancellation-node": "^0.1.9"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
